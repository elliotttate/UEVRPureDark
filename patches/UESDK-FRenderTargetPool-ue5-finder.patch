+
+std::optional<uintptr_t> FRenderTargetPool::get_find_free_element_return_fn(bool is_ue5) {
+    if (!is_ue5) {
+        return std::nullopt;
+    }
+
+    static auto result = []() -> std::optional<uintptr_t> {
+        const auto bool_overload = get_find_free_element_fn(true);
+        if (!bool_overload) {
+            return std::nullopt;
+        }
+
+        const auto overload_module = utility::get_module_within(Address{ *bool_overload });
+        if (!overload_module) {
+            SPDLOG_ERROR("Failed to identify module for FRenderTargetPool::FindFreeElement bool overload {:x}",
+                         *bool_overload);
+            return std::nullopt;
+        }
+
+        const auto overload_module_size = utility::get_module_size(*overload_module);
+        if (!overload_module_size || *overload_module_size == 0) {
+            SPDLOG_ERROR("Failed to get module size for FRenderTargetPool::FindFreeElement bool overload {:x}",
+                         *bool_overload);
+            return std::nullopt;
+        }
+
+        const auto module_start = (uintptr_t)*overload_module;
+        const auto module_end = module_start + *overload_module_size;
+        if (*bool_overload < module_start || *bool_overload >= module_end) {
+            SPDLOG_ERROR("Rejected FRenderTargetPool::FindFreeElement bool overload outside module range {:x}",
+                         *bool_overload);
+            return std::nullopt;
+        }
+
+        // UE5 has two exported/inlined shapes:
+        //   bool FindFreeElement(RHICmdList, Desc, Out, Name)
+        //   TRefCountPtr FindFreeElement(RHICmdList, Desc, Name)
+        // Direct named pool users usually hit the bool overload. RDG's
+        // AllocatePooledRenderTargetRHI hits the TRef-returning overload. In
+        // 5.5/5.6 shipping builds the TRef overload is emitted immediately
+        // before the bool overload, separated by an INT3 padding run. Walk back
+        // over two padding runs to find the prior function boundary instead of
+        // hardcoding a build-specific offset.
+        constexpr uintptr_t scan_back = 0x400;
+        const auto min_addr = (std::max)(module_start, *bool_overload > scan_back ? *bool_overload - scan_back : 0);
+        uintptr_t cursor = *bool_overload - 1;
+        uint32_t padding_runs = 0;
+
+        while (cursor > min_addr) {
+            if (*(uint8_t*)cursor != 0xCC) {
+                --cursor;
+                continue;
+            }
+
+            const auto run_end = cursor;
+            while (cursor > min_addr && *((uint8_t*)cursor - 1) == 0xCC) {
+                --cursor;
+            }
+            const auto run_start = cursor;
+            const auto run_len = run_end - run_start + 1;
+
+            if (run_len >= 4) {
+                ++padding_runs;
+                if (padding_runs == 2) {
+                    const auto candidate = run_end + 1;
+                    if (candidate >= module_start && candidate < *bool_overload && *(uint8_t*)candidate != 0xCC) {
+                        SPDLOG_INFO("Found UE5 TRef-returning FRenderTargetPool::FindFreeElement at {:x} (bool overload {:x})",
+                                    candidate, *bool_overload);
+                        return candidate;
+                    }
+
+                    SPDLOG_ERROR("Rejected UE5 TRef-returning FRenderTargetPool::FindFreeElement candidate {:x}",
+                                 candidate);
+                    return std::nullopt;
+                }
+            }
+
+            if (cursor == min_addr) {
+                break;
+            }
+            --cursor;
+        }
+
+        SPDLOG_ERROR("Failed to derive UE5 TRef-returning FRenderTargetPool::FindFreeElement from bool overload {:x}",
+                     *bool_overload);
+        return std::nullopt;
+    }();
+
+    return result;
+}
+}
